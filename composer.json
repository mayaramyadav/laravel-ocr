{
  "name": "mayaram/laravel-ocr",
  "description": "Laravel OCR & Document Data Extractor - A powerful OCR and document parsing engine for Laravel",
  "keywords": [
    "ocr laravel",
    "laravel",
    "laravel ocr",
    "Laravel OCR image to text",
    "ocr",
    "document",
    "parser",
    "tesseract",
    "pdf",
    "invoice",
    "receipt",
    "AWS Text Extractor",
    "Google Vision",
    "Azure OCR",
    "laravel tesseract ocr",
    "laravel ocr package",
    "ocr php laravel",
    "laravel ocr image",
    "laravel ocr pdf to text",
    "laravel ocr image to text",
    "laravel ocr pdf to image to text",
    "laravel ocr image to pdf to text"
  ],
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Laravel OCR Team",
      "email": "info@mayaram.in"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "thiagoalessio/tesseract_ocr": "^2.12",
    "smalot/pdfparser": "^2.0",
    "intervention/image": "^3.0",
    "guzzlehttp/guzzle": "^7.0",
    "aws/aws-sdk-php": "^3.369",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.5|^12.0",
    "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.0|^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Mayaram\\LaravelOcr\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mayaram\\LaravelOcr\\Tests\\": "tests/"
    }
  },
  "suggest": {
    "laravel/ai": "Optional. Install to enable AI-powered cleanup and structured extraction. Current laravel/ai releases require newer PHP/Laravel versions than the core OCR package.",
    "google/cloud-vision": "Required to use the Google Vision driver.",
    "aws/aws-sdk-php": "Required to use the AWS Textract driver.",
    "guzzlehttp/guzzle": "Required to use the Azure OCR driver."
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mayaram\\LaravelOcr\\LaravelOcrServiceProvider"
      ],
      "aliases": {
        "LaravelOcr": "Mayaram\\LaravelOcr\\Facades\\LaravelOcr"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
